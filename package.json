{
  "name": "@mizchi/flaker",
  "version": "0.12.0",
  "description": "Flaky test detection, sampling, and test runner orchestration",
  "type": "module",
  "bin": {
    "flaker": "./dist/cli/main.js"
  },
  "exports": {
    "./reporting/stable-test-identity": {
      "types": "./dist/cli/reporting/stable-test-identity.d.ts",
      "default": "./dist/cli/reporting/stable-test-identity.js"
    },
    "./reporting/playwright-report-contract": {
      "types": "./dist/cli/reporting/playwright-report-contract.d.ts",
      "default": "./dist/cli/reporting/playwright-report-contract.js"
    },
    "./reporting/playwright-report-summary-core": {
      "types": "./dist/cli/reporting/playwright-report-summary-core.d.ts",
      "default": "./dist/cli/reporting/playwright-report-summary-core.js"
    },
    "./reporting/playwright-report-diff-core": {
      "types": "./dist/cli/reporting/playwright-report-diff-core.d.ts",
      "default": "./dist/cli/reporting/playwright-report-diff-core.js"
    },
    "./reporting/flaker-task-summary-contract": {
      "types": "./dist/cli/reporting/flaker-task-summary-contract.d.ts",
      "default": "./dist/cli/reporting/flaker-task-summary-contract.js"
    },
    "./reporting/flaker-task-summary-core": {
      "types": "./dist/cli/reporting/flaker-task-summary-core.d.ts",
      "default": "./dist/cli/reporting/flaker-task-summary-core.js"
    },
    "./reporting/flaker-batch-summary-core": {
      "types": "./dist/cli/reporting/flaker-batch-summary-core.d.ts",
      "default": "./dist/cli/reporting/flaker-batch-summary-core.js"
    }
  },
  "scripts": {
    "build": "node ./scripts/build-package.mjs",
    "build:package": "node ./scripts/build-package.mjs",
    "cli": "node dist/cli/main.js",
    "dev:cli": "node ./scripts/dev-cli.mjs",
    "pack:check": "npm pack --dry-run --cache ./.npm-cache",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "keywords": [],
  "author": "mizchi",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizchi/flaker.git"
  },
  "homepage": "https://github.com/mizchi/flaker#readme",
  "bugs": {
    "url": "https://github.com/mizchi/flaker/issues"
  },
  "files": [
    "dist/cli/**",
    "dist/moonbit/flaker.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "duckdb"
    ]
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "adm-zip": "^0.5.17",
    "commander": "^14.0.3",
    "duckdb": "^1.4.4",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.5.2",
    "rolldown": "1.0.0-rc.12",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
