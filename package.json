{
  "name": "@mizchi/flaker",
  "version": "0.1.1",
  "description": "Flaky test detection, sampling, and test runner orchestration",
  "type": "module",
  "bin": {
    "flaker": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "node ./scripts/build-package.mjs",
    "build:package": "node ./scripts/build-package.mjs",
    "cli": "node dist/cli/main.js",
    "pack:check": "npm pack --dry-run --cache ./.npm-cache",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "files": [
    "dist/cli/main.js",
    "dist/moonbit/flaker.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "duckdb"
    ]
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "adm-zip": "^0.5.17",
    "commander": "^14.0.3",
    "duckdb": "^1.4.4",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.5.2",
    "rolldown": "1.0.0-rc.12",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
